NEXT_PUBLIC_APP_URL=https://your-production-domain.com
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe (use test keys for development, live keys for production)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# SmartBill (Romanian invoicing)
SMARTBILL_USERNAME=your_smartbill_email
SMARTBILL_TOKEN=your_smartbill_token
SMARTBILL_COMPANY_VAT_CODE=your_company_vat_code
SMARTBILL_TAX_PERCENTAGE=0
SMARTBILL_TAX_NAME=SFDD
# Leave SMARTBILL_SERIES_NAME empty to use your default series from SmartBill account
SMARTBILL_SERIES_NAME=

# Email (Resend)
RESEND_API_KEY=re_...
